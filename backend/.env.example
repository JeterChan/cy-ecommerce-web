# Database Configuration
DB_USER=user
DB_PASSWORD=password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecommerce_db
DATABASE_URL=

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# JWT Configuration
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Shopping Cart Guest Token Configuration
GUEST_TOKEN_COOKIE_NAME=guest_cart_token
GUEST_TOKEN_MAX_AGE=604800  # 7 days in seconds
GUEST_TOKEN_PATH=/api/cart
GUEST_TOKEN_SECURE=false  # Set to true in production
GUEST_TOKEN_SAMESITE=lax  # Options: strict, lax, none

# AWS S3 Settings
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=your_bucket_name
AWS_S3_REGION=ap-northeast-1

