# =============================================================================
# GCE VM 環境變數範本
# 複製此檔案為 .env 並填入正式值
#   cp scripts/gcp/vm/.env.example scripts/gcp/vm/.env
# =============================================================================

# --- Docker Image（來自 Artifact Registry）---
IMAGE_FULL=asia-east1-docker.pkg.dev/cy-ecommerce-v1/cy-ecommerce-repo/cy-ecommerce-api

# --- Cloud SQL Auth Proxy ---
# 格式: PROJECT_ID:REGION:INSTANCE_NAME
CLOUD_SQL_CONNECTION_NAME=cy-ecommerce-v1:asia-east1:cy-ecommerce-db

# --- 資料庫（Celery Worker 用，透過 cloud-sql-proxy 連線）---
DB_USER=ecommerce_user
DB_PASSWORD=your-db-password
DB_NAME=ecommerce

# --- Celery Worker 所需的其他環境變數 ---
SECRET_KEY=your-jwt-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=your@email.com
BREVO_SENDER_NAME=cyWeb
FRONTEND_URL=https://your-app.vercel.app

AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=cy-ecommerce-bucket
AWS_S3_REGION=ap-northeast-1

GUEST_TOKEN_COOKIE_NAME=guest_cart_token
GUEST_TOKEN_MAX_AGE=604800
GUEST_TOKEN_PATH=/api/cart
GUEST_TOKEN_SECURE=true
GUEST_TOKEN_SAMESITE=none

PROJECT_NAME=E-commerce Backend
ENV=production

# --- Cloud Scheduler 清理 API 金鑰（Cloud Run 和 Scheduler 共用同一組）---
CLEANUP_API_KEY=your-cleanup-api-key